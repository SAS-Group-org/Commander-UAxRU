        },
        "misc": {
            "shape": "rounded_rectangle",
            "shape_corner_radius": "4",
            "border_width": "1"
        }
    },
    "selection_list": {
        "colours": {
            "dark_bg": "#151816",
            "normal_bg": "#151816",
