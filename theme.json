{
    "window": {
        "colours": {
            "dark_bg": "#1e2220",
            "normal_bg": "#2b302c",
            "window_bg": "#2b302c",
            "border": "#4a524c"
        },
        "misc": {
            "border_width": "2",
            "shadow_width": "5"
        }
    },
    "panel": {
        "colours": {
            "dark_bg": "#1e2220",
            "normal_bg": "#1e2220",
            "panel_bg": "#1e2220",
            "border": "#4a524c"
        },
        "misc": {
            "border_width": "2"
        }
    },
    "label": {
        "colours": {
            "normal_text": "#e0d8c0"
        },
        "font": {
            "name": "noto_sans",
            "size": "14",
            "bold": "1"
        },
        "misc": {
            "text_horiz_alignment": "left"
        }
    },
    "button": {
        "colours": {
            "normal_bg": "#363c37",
            "hovered_bg": "#4a524c",
            "active_bg": "#1e2220",
            "normal_text": "#e0d8c0",
            "hovered_text": "#ffffff",
            "normal_border": "#1a1c1a",
